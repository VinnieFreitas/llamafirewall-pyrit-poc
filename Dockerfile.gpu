# =============================================================================
#  LlamaFirewall Proxy — GPU Build
#  For: corp-prod AKS (NC-series T4/A100 node pool)
#
#  Usage:
#    docker build -t llamafirewall-proxy:gpu -f Dockerfile.gpu \
#      --build-arg HF_TOKEN=hf_xxx .
#
#    # Run with GPU
#    docker run --gpus all -p 8080:8080 \
#      -e OLLAMA_BASE_URL=http://<ollama-host>:11434 \
#      -e LLAMAFIREWALL_PROFILE=production \
#      -e PROMPTGUARD_THRESHOLD=0.15 \
#      -e OUTPUT_SCAN_ENABLED=1 \
#      -e NOVA_LLM_ENABLED=1 \
#      llamafirewall-proxy:gpu
#
#  AKS deployment — request GPU in pod spec:
#    resources:
#      limits:
#        nvidia.com/gpu: 1
# =============================================================================

# CUDA 12.1 + cuDNN 8 on Ubuntu 22.04 — matches Azure NC T4 v3 driver
FROM nvidia/cuda:12.1.0-cudnn8-runtime-ubuntu22.04

# ---------------------------------------------------------------------------
#  System dependencies
# ---------------------------------------------------------------------------
RUN apt-get update -qq && \
    apt-get install -y -qq --no-install-recommends \
        python3.10 \
        python3.10-dev \
        python3-pip \
        python3.10-venv \
        git \
        curl \
        build-essential \
        libssl-dev \
        libffi-dev \
    && rm -rf /var/lib/apt/lists/* \
    && ln -s /usr/bin/python3.10 /usr/local/bin/python3

# ---------------------------------------------------------------------------
#  Python dependencies — CUDA-enabled torch
# ---------------------------------------------------------------------------
RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir \
        torch \
        --index-url https://download.pytorch.org/whl/cu121 && \
    pip install --no-cache-dir \
        llamafirewall \
        transformers \
        fastapi \
        uvicorn \
        httpx \
        nova-hunting

# ---------------------------------------------------------------------------
#  HfFolder compatibility patch
# ---------------------------------------------------------------------------
RUN python3 -c "\
import os, sys; \
path = next((os.path.join(r, 'llamafirewall/scanners/promptguard_utils.py') \
    for r in sys.path if os.path.exists(os.path.join(r, 'llamafirewall/scanners/promptguard_utils.py'))), None); \
content = open(path).read(); \
old = 'from huggingface_hub import HfFolder, login'; \
new = '''from huggingface_hub import login\ntry:\n    from huggingface_hub import HfFolder\nexcept ImportError:\n    import huggingface_hub as _hf\n    class HfFolder:\n        @staticmethod\n        def get_token(): return _hf.get_token()\n        @staticmethod\n        def save_token(token): pass'''; \
open(path, 'w').write(content.replace(old, new)) if old in content else None; \
print('HfFolder patch applied' if old in content else 'HfFolder already patched')"

# ---------------------------------------------------------------------------
#  Application files
# ---------------------------------------------------------------------------
WORKDIR /app

COPY proxy.py                             ./proxy.py
COPY social_engineering_pt.nov            ./nova-rules-custom/social_engineering_pt.nov

RUN git clone --depth 1 https://github.com/Nova-Hunting/nova-rules ./nova-rules

# ---------------------------------------------------------------------------
#  Pre-download PromptGuard 2 weights
# ---------------------------------------------------------------------------
ARG HF_TOKEN=""
ENV HF_HOME=/app/.cache/huggingface
RUN if [ -n "${HF_TOKEN}" ]; then \
        python3 -c "\
import os; \
os.environ['HUGGING_FACE_HUB_TOKEN'] = '${HF_TOKEN}'; \
from transformers import AutoTokenizer, AutoModelForSequenceClassification; \
model_id = 'meta-llama/Llama-Prompt-Guard-2-86M'; \
AutoTokenizer.from_pretrained(model_id, token='${HF_TOKEN}'); \
AutoModelForSequenceClassification.from_pretrained(model_id, token='${HF_TOKEN}'); \
print('PromptGuard 2 weights cached.')"; \
    else \
        echo "No HF_TOKEN — PromptGuard 2 will download on first request."; \
    fi

# ---------------------------------------------------------------------------
#  Runtime environment defaults — production profile
# ---------------------------------------------------------------------------
ENV LLAMAFIREWALL_PROFILE=production \
    PROMPTGUARD_THRESHOLD=0.15 \
    OUTPUT_SCAN_ENABLED=1 \
    NOVA_LLM_ENABLED=1 \
    LLAMA_GUARD_DISABLED=0 \
    BYPASS_MODE=0 \
    NO_LLM=0 \
    OLLAMA_BASE_URL=http://localhost:11434 \
    PYTHONUNBUFFERED=1

# ---------------------------------------------------------------------------
#  Non-root user
# ---------------------------------------------------------------------------
RUN useradd -m -u 1000 llamafirewall
RUN chown -R llamafirewall:llamafirewall /app
USER llamafirewall

HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
    CMD curl -sf http://localhost:8080/health || exit 1

EXPOSE 8080

CMD ["uvicorn", "proxy:app", \
     "--host", "0.0.0.0", \
     "--port", "8080", \
     "--workers", "1", \
     "--log-level", "warning"]
